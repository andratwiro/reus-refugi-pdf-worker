{
  "name": "mercurio-mock",
  "version": "0.1.0",
  "description": "Mock server for Mercurio. Replica les rutes mínimes per testejar el mapper Airtable→Mercurio offline. NO conté el userscript de producció (viu a src/mercurio/userscriptCode.ts del Worker).",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "test": "tsx test/run.ts",
    "test:uploads": "tsx test/run-uploads.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "tsx": "^4.7.2",
    "typescript": "^5.5.0"
  }
}
